{
    "name": "tropk-ai/mcp-for-wordpress",
    "description": "MCP for WP, Elementor and more by Tropk.ai — turns any WordPress site into a Model Context Protocol server for Claude.ai, ChatGPT and other AI assistants. 450+ tools, original code, no third-party plugins bundled.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/tropk-ai/mcp-for-wordpress",
    "authors": [
        { "name": "Tropk.ai", "homepage": "https://tropk.ai" }
    ],
    "require": {
        "php": ">=8.1",
        "wordpress/abilities-api": "^0.3 || ^0.2",
        "wordpress/mcp-adapter": "^0.5",
        "wordpress/php-mcp-schema": "^0.1",
        "automattic/jetpack-autoloader": "^5.0 || ^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.6",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Tropk\\Mcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tropk\\Mcp\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "automattic/jetpack-autoloader": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "autoloader-suffix": "TropkMcpForWordpress"
    }
}
